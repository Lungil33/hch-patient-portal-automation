# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed to source control —
# it contains credentials and environment-specific URLs.

# ── Portal URL ─────────────────────────────────────────────────────────────────
# Full URL of the HCH patient portal (no trailing slash).
# Example: https://patients.hch.org.au
HCH_PORTAL_URL=https://your-hch-portal.example.com

# ── Test patient credentials ───────────────────────────────────────────────────
# A dedicated test patient account — never use a real patient's credentials.
# This account is used by global-setup.ts to log in and save the session.
HCH_PATIENT_EMAIL=testpatient@example.com
HCH_PATIENT_PASSWORD=your-password-here

# ── Appointment booking test data ──────────────────────────────────────────────
# The service type to select on the booking form.
# Must match the exact option label shown in the portal dropdown.
HCH_SERVICE_TYPE=General Practice

# The provider/clinician to select.
# Must match the exact name shown in the portal provider list.
HCH_PROVIDER_NAME=Dr. Test Provider

# The preferred booking date in YYYY-MM-DD format.
# Pick a future date that is likely to have available slots in your test env.
HCH_PREFERRED_DATE=2026-04-01

# ── Dynamics 365 / Power Apps — chatbot tests (P-03 → P-09) ───────────────────
# Full URL of the HCH Power Apps / Dynamics 365 UAT application.
# This is the appid-scoped URL — copy it exactly from the browser address bar.
# Do NOT add a trailing slash.
HCH_DYNAMICS_URL=https://healthcollectivehealuat.crm14.dynamics.com/main.aspx?appid=fb252b70-5d34-45c8-9397-975ddb4db3d9&pagetype=entitylist&etn=contact&viewid=00000000-0000-0000-00aa-000010001004&viewType=1039

# Microsoft 365 / Entra ID credentials used to log in to Dynamics 365.
# The login flow goes through login.microsoftonline.com (Microsoft OAuth / MSAL).
# Must be a licensed Dynamics 365 user in the UAT tenant.
# NEVER commit real credentials — this file is a template only.
HCH_DYNAMICS_EMAIL=Lungile@riivo.io
HCH_DYNAMICS_PASSWORD=your-dynamics-password-here

# Patient ID supplied to the bot when it asks for identification (P-05).
# Set this to the patient ID linked to the test account in the UAT system.
HCH_PATIENT_ID=12345
